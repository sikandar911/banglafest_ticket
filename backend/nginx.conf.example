# Nginx configuration for backend API
# Location: /etc/nginx/sites-available/api.banglafest.co.uk
# Commands to enable:
#   sudo cp nginx.conf.example /etc/nginx/sites-available/api.banglafest.co.uk
#   sudo ln -s /etc/nginx/sites-available/api.banglafest.co.uk /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx

# HTTP - Redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name api.banglafest.co.uk;

    return 301 https://$host$request_uri;
}

# HTTPS - Main server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.banglafest.co.uk;

    # SSL Certificate paths - Certbot will create these
    # Run: sudo certbot --nginx -d api.banglafest.co.uk
    ssl_certificate /etc/letsencrypt/live/api.banglafest.co.uk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.banglafest.co.uk/privkey.pem;

    # SSL Configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5:!3DES;
    ssl_stapling on;
    ssl_stapling_verify on;

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Access logs
    access_log /var/log/nginx/api.banglafest.co.uk.access.log;
    error_log /var/log/nginx/api.banglafest.co.uk.error.log;

    # Proxy settings
    client_max_body_size 50M;
    proxy_buffering off;

    # Root location - proxy to Docker backend on 127.0.0.1:5000
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        
        # Essential headers for proxying
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        
        # WebSocket support (if needed)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Health check endpoint
    location /api/health {
        proxy_pass http://127.0.0.1:5000/api/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        access_log off;
    }
}
