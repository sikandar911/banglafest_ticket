# ==========================================
# Banglafest Backend Docker Configuration
# ==========================================
# Internal Docker PostgreSQL Database
# Copy this file to .env and update values

# Application Environment
NODE_ENV=production

# ==========================================
# Database Configuration (Internal Docker)
# ==========================================
# Using Docker network: db:5432
# This connects to PostgreSQL container in same docker-compose.yml
DATABASE_URL="postgresql://postgresamb:sikku321@db:5432/ticketbanglafest?schema=public"

# ==========================================
# Backend Configuration
# ==========================================

# Server Port
BACKEND_PORT=5000

# JWT Secrets (IMPORTANT: Change these in production)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://ticket.banglafest.co.uk

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-email@hostinger.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@banglafest.co.uk

# OTP Configuration
OTP_EXPIRES_IN_MINUTES=15
