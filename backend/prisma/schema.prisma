generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  isVerified          Boolean   @default(false) @map("is_verified")
  role                Role      @default(USER)
  createdAt           DateTime  @default(now()) @map("created_at")
  otpCode             String?   @map("otp_code")
  otpExpiresAt        DateTime? @map("otp_expires_at")
  resetToken          String?   @map("reset_token")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  refreshToken        String?   @map("refresh_token")
  eventsCreated       Event[]   @relation("EventCreatedBy")
  orders              Order[]
  tickets             Ticket[]
  salesOrders         Order[]   @relation("SalesOrders")

  @@map("users")
}

model Event {
  id               String       @id @default(uuid())
  title            String
  description      String?
  startTime        DateTime     @map("start_time")
  endTime          DateTime     @map("end_time")
  location         String?
  createdBy        String?      @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  imageUrl         String?      @map("image_url")
  performers       String?      // JSON: [{name, ticketDisplayName}]
  specialAdditions String?      @map("special_additions") // JSON: [{name, description, ticketDisplayText}]
  creator          User?        @relation("EventCreatedBy", fields: [createdBy], references: [id])
  ticketTiers      TicketTier[]
  promoCodes  PromoCodeEvent[]

  @@map("events")
}

model TicketTier {
  id                  String      @id @default(uuid())
  eventId             String      @map("event_id")
  name                String
  price               Decimal     @db.Decimal(10, 2)
  totalCapacity       Int         @map("total_capacity")
  availableQty        Int         @map("available_qty")
  description         String?
  features            String?
  maxPerPerson        Int         @default(1) @map("max_per_person")
  promoDiscountAmount Decimal?    @map("promo_discount_amount") @db.Decimal(10, 2)
  orderItems          OrderItem[]
  orders              Order[]     @relation("OrderTier")
  event               Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets             Ticket[]

  @@map("ticket_tiers")
}

model Order {
  id                  String      @id @default(uuid())
  userId              String      @map("user_id")
  tierId              String      @map("tier_id")
  quantity            Int         @default(1)
  totalAmount         Decimal     @map("total_amount") @db.Decimal(10, 2)
  stripeSessionId     String?     @map("stripe_session_id")
  stripePaymentIntent String?     @map("stripe_payment_intent")
  status              OrderStatus @default(PENDING)
  expiresAt           DateTime    @map("expires_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  isBypassed          Boolean       @default(false) @map("is_bypassed")
  promoCodeId         String?       @map("promo_code_id")
  discountAmount      Decimal?      @map("discount_amount") @db.Decimal(10, 2)
  salesExecutiveId    String?       @map("sales_executive_id")
  paymentMethod       PaymentMethod @default(ONLINE) @map("payment_method")
  attendeeNames       String?       @map("attendee_names") // JSON array of names per ticket slot
  items               OrderItem[]
  ticketTier          TicketTier    @relation("OrderTier", fields: [tierId], references: [id])
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode           PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  salesExecutive      User?         @relation("SalesOrders", fields: [salesExecutiveId], references: [id], onDelete: SetNull)
  tickets             Ticket[]

  @@map("orders")
}

model OrderItem {
  id           String     @id @default(uuid())
  orderId      String     @map("order_id")
  tierId       String     @map("tier_id")
  quantity     Int
  pricePerUnit Decimal    @map("price_per_unit") @db.Decimal(10, 2)
  subtotal     Decimal    @db.Decimal(10, 2)
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tier         TicketTier @relation(fields: [tierId], references: [id])

  @@unique([orderId, tierId])
  @@map("order_items")
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  influencerName String    @map("influencer_name")
  socialMedia    String?   @map("social_media")
  discountAmount Decimal?  @map("discount_amount") @db.Decimal(10, 2)
  isActive       Boolean   @default(true) @map("is_active")
  usageCount     Int       @default(0) @map("usage_count")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  events PromoCodeEvent[]
  orders Order[]

  @@map("promo_codes")
}

model PromoCodeEvent {
  promoCodeId String @map("promo_code_id")
  eventId     String @map("event_id")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, eventId])
  @@map("promo_code_events")
}

model Ticket {
  id           String       @id @default(uuid())
  orderId      String       @map("order_id")
  ticketTierId String       @map("ticket_tier_id")
  userId       String       @map("user_id")
  status       TicketStatus @default(VALID)
  scannedAt    DateTime?    @map("scanned_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  attendeeName String?      @map("attendee_name")
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTier   TicketTier   @relation(fields: [ticketTierId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tickets")
}

enum Role {
  USER
  ADMIN
  SCANNER
  SALES_EXECUTIVE
}

enum PaymentMethod {
  ONLINE
  CASH
  CARD_MACHINE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TicketStatus {
  VALID
  CHECKED_IN
  CANCELLED
}
