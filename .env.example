# ==========================================
# Banglafest Docker Deployment Configuration
# ==========================================
# Copy this file to .env and update values

# Application Environment
NODE_ENV=production

# ==========================================
# Database Configuration
# ==========================================
DB_USER=banglafest
DB_PASSWORD=changeme_in_production
DB_NAME=banglafest

# ==========================================
# Backend Configuration
# ==========================================

# JWT Secrets (IMPORTANT: Change these in production)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# URLs
FRONTEND_URL=http://ticket.banglafest.co.uk
BACKEND_URL=http://api.banglafest.co.uk

# Stripe Payment Gateway
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@banglafest.co.uk

# OTP Configuration
OTP_EXPIRES_IN_MINUTES=15

# ==========================================
# Frontend Configuration
# ==========================================
VITE_API_URL=http://api.banglafest.co.uk

# ==========================================
# Docker Ports (change if needed)
# ==========================================
# Backend: 5000
# Frontend: 3000
# Database: 5432
