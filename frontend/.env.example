# ==========================================
# Banglafest Frontend Docker Configuration
# ==========================================
# Copy this file to .env and update values

# Frontend Port (in Docker)
FRONTEND_PORT=3000

# Backend API URL
# This is the URL where the frontend will call the backend API
# In production, this should be your API domain
VITE_API_URL=http://api.banglafest.co.uk

# Note: For local development with Docker:
# - Frontend will be at: http://localhost:3000
# - Backend should be accessible at the VITE_API_URL
# 
# The frontend makes API calls from the browser, so:
# - If backend is on same machine: use http://localhost:5000 or your backend domain
# - If backend is on different machine: use the backend's actual IP/domain
